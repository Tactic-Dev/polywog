{
  "name": "@polywog/core",
  "version": "1.0.0",
  "description": "Polywog Core – orchestration wrapper that stitches the six axle modules into one end-to-end execution pipeline",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["polywog", "orchestration", "ai", "pipeline"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "zod": "^3.24.2"
  }
}
